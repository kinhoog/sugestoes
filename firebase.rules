rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verifiedCorporateUser() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('^[^@]+@protege\\.med\\.br$');
    }

    function isAdmin() {
      return verifiedCorporateUser()
        && request.auth.token.email in [
          'fabio@protege.med.br',
          'abner@protege.med.br',
          'esocial@protege.med.br'
        ];
    }

    function isOwner(uid) {
      return verifiedCorporateUser() && request.auth.uid == uid;
    }

    function onlyChanged(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    function validProtocol() {
      return request.resource.data.protocolo is string
        && request.resource.data.protocolo.matches('^PRO-[0-9]{4}-[0-9]{4,}$');
    }

    function validReferenciaEvidencia() {
      return !request.resource.data.keys().hasAny(['referencia_evidencia'])
        || request.resource.data.referencia_evidencia == null
        || request.resource.data.referencia_evidencia is string;
    }

    function validStatusValue(status) {
      return status in [
        'Nova',
        'Em Análise',
        'Aguardando Informações',
        'Aprovada',
        'Rejeitada',
        'Concluída'
      ];
    }

    function validStatusPublicoValue(status) {
      return status in [
        'Pendente',
        'Em análise',
        'Aguardando informações',
        'Aprovada',
        'Rejeitada',
        'Concluída'
      ];
    }

    function validHistoricoTipoEvento(tipo) {
      return tipo in [
        'criacao',
        'alteracao_status',
        'atribuicao_responsavel',
        'observacao_interna',
        'resposta_publica'
      ];
    }

    function validSolicitacaoCreateFields() {
      return request.resource.data.keys().hasOnly([
        'protocolo',
        'nome_completo',
        'email',
        'setor_id',
        'cargo_id',
        'processo_alvo',
        'funcionamento_atual',
        'frequencia',
        'impacto_operacional',
        'pessoas_impactadas',
        'tempo_perdido',
        'informacoes_complementares',
        'referencia_evidencia',
        'usa_planilha',
        'descricao_planilha',
        'usa_email',
        'descricao_email',
        'atividade_repetitiva',
        'descricao_atividade_repetitiva',
        'dependencia_pessoa',
        'descricao_dependencia_pessoa',
        'resultado_ideal',
        'urgencia',
        'score',
        'prioridade_calculada',
        'status',
        'created_by',
        'created_by_email',
        'data_criacao',
        'data_inicio_analise',
        'data_decisao',
        'data_fechamento',
        'parecer_tecnico',
        'observacao_interna',
        'deleted_at',
        'updated_at'
      ]);
    }

    function validHistoricoFields() {
      return request.resource.data.keys().hasAll([
        'solicitacao_id',
        'protocolo',
        'tipo_evento',
        'status_anterior',
        'status_novo',
        'observacao',
        'usuario_id',
        'usuario_email',
        'data_alteracao'
      ])
      && request.resource.data.keys().hasOnly([
        'solicitacao_id',
        'protocolo',
        'tipo_evento',
        'status_anterior',
        'status_novo',
        'observacao',
        'usuario_id',
        'usuario_email',
        'data_alteracao'
      ]);
    }

    function validSolicitacaoPublicaFields() {
      return request.resource.data.keys().hasAll([
        'solicitacao_id',
        'protocolo',
        'created_by',
        'created_by_email',
        'status_publico',
        'status_interno',
        'created_at'
      ])
      && request.resource.data.keys().hasOnly([
        'solicitacao_id',
        'protocolo',
        'created_by',
        'created_by_email',
        'solicitante_nome',
        'setor',
        'cargo',
        'processo_atividade',
        'status_publico',
        'status_interno',
        'resposta_publica',
        'created_at',
        'updated_at'
      ])
      && request.resource.data.solicitacao_id is string
      && request.resource.data.solicitacao_id != ''
      && request.resource.data.created_by is string
      && request.resource.data.created_by_email is string
      && validProtocol()
      && validStatusPublicoValue(request.resource.data.status_publico)
      && validStatusValue(request.resource.data.status_interno)
      && (
        !request.resource.data.keys().hasAny(['solicitante_nome'])
        || request.resource.data.solicitante_nome == null
        || request.resource.data.solicitante_nome is string
      )
      && (
        !request.resource.data.keys().hasAny(['setor'])
        || request.resource.data.setor == null
        || request.resource.data.setor is string
      )
      && (
        !request.resource.data.keys().hasAny(['cargo'])
        || request.resource.data.cargo == null
        || request.resource.data.cargo is string
      )
      && (
        !request.resource.data.keys().hasAny(['processo_atividade'])
        || request.resource.data.processo_atividade == null
        || request.resource.data.processo_atividade is string
      )
      && (
        !request.resource.data.keys().hasAny(['resposta_publica'])
        || request.resource.data.resposta_publica == null
        || request.resource.data.resposta_publica is string
      );
    }

    match /usuarios/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (
          request.resource.data.perfil == 'colaborador'
          || (isAdmin() && request.resource.data.perfil == 'admin')
        );
      allow update: if isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.perfil == resource.data.perfil;
      allow delete: if false;
    }

    match /setores/{setorId} {
      allow read: if verifiedCorporateUser();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /cargos/{cargoId} {
      allow read: if verifiedCorporateUser();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /contadores/{contadorId} {
      allow get: if verifiedCorporateUser();
      allow create: if verifiedCorporateUser()
        && request.resource.data.keys().hasOnly(['ano', 'ultimo_numero', 'updated_at'])
        && request.resource.data.ultimo_numero == 1;
      allow update: if verifiedCorporateUser()
        && request.resource.data.keys().hasOnly(['ano', 'ultimo_numero', 'updated_at'])
        && request.resource.data.ano == resource.data.ano
        && request.resource.data.ultimo_numero == resource.data.ultimo_numero + 1;
      allow delete: if false;
    }

    match /solicitacoes/{solicitacaoId} {
      allow get, list: if isAdmin();

      allow create: if verifiedCorporateUser()
        && request.resource.data.created_by == request.auth.uid
        && request.resource.data.created_by_email == request.auth.token.email
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.status == 'Nova'
        && request.resource.data.deleted_at == null
        && validProtocol()
        && validReferenciaEvidencia()
        && validStatusValue(request.resource.data.status)
        && validSolicitacaoCreateFields()
        && request.resource.data.keys().hasAll([
          'protocolo',
          'nome_completo',
          'email',
          'setor_id',
          'cargo_id',
          'processo_alvo',
          'funcionamento_atual',
          'frequencia',
          'impacto_operacional',
          'pessoas_impactadas',
          'tempo_perdido',
          'usa_planilha',
          'usa_email',
          'atividade_repetitiva',
          'dependencia_pessoa',
          'resultado_ideal',
          'urgencia',
          'score',
          'prioridade_calculada',
          'status',
          'created_by',
          'created_by_email',
          'data_criacao',
          'deleted_at'
        ])
        && request.resource.data.parecer_tecnico == null
        && request.resource.data.observacao_interna == null;

      allow update: if isAdmin()
        && request.resource.data.protocolo == resource.data.protocolo
        && request.resource.data.created_by == resource.data.created_by
        && request.resource.data.score == resource.data.score
        && request.resource.data.prioridade_calculada == resource.data.prioridade_calculada
        && validStatusValue(request.resource.data.status)
        && request.resource.data.updated_by == request.auth.uid
        && request.resource.data.updated_by_email == request.auth.token.email
        && onlyChanged([
          'status',
          'parecer_tecnico',
          'observacao_interna',
          'resposta_publica',
          'responsavel_admin_id',
          'responsavel_admin_email',
          'responsavel_admin_nome',
          'data_inicio_analise',
          'data_decisao',
          'data_fechamento',
          'updated_at',
          'updated_by',
          'updated_by_email',
          'deleted_at'
        ]);

      allow delete: if false;
    }

    match /solicitacoes_publicas/{solicitacaoId} {
      allow get: if isAdmin() || isOwner(resource.data.created_by);
      allow list: if isAdmin() || isOwner(resource.data.created_by);

      allow create: if validSolicitacaoPublicaFields()
        && request.resource.data.solicitacao_id == solicitacaoId
        && (
          isAdmin()
          || (
            verifiedCorporateUser()
            && request.resource.data.created_by == request.auth.uid
            && request.resource.data.created_by_email == request.auth.token.email
            && request.resource.data.status_publico == 'Pendente'
            && request.resource.data.status_interno == 'Nova'
            && request.resource.data.resposta_publica == null
            && getAfter(/databases/$(database)/documents/solicitacoes/$(solicitacaoId)).data.created_by == request.auth.uid
            && getAfter(/databases/$(database)/documents/solicitacoes/$(solicitacaoId)).data.protocolo == request.resource.data.protocolo
          )
        );

      allow update: if isAdmin()
        && validSolicitacaoPublicaFields()
        && request.resource.data.solicitacao_id == resource.data.solicitacao_id
        && request.resource.data.protocolo == resource.data.protocolo
        && request.resource.data.created_by == resource.data.created_by
        && request.resource.data.created_by_email == resource.data.created_by_email
        && onlyChanged([
          'solicitante_nome',
          'setor',
          'cargo',
          'processo_atividade',
          'status_publico',
          'status_interno',
          'resposta_publica',
          'created_at',
          'updated_at'
        ]);

      allow delete: if false;
    }

    match /historico_status/{historicoId} {
      allow get, list: if isAdmin();
      allow create: if validHistoricoFields()
        && (
          (
            isAdmin()
            && request.resource.data.usuario_id == request.auth.uid
            && request.resource.data.usuario_email == request.auth.token.email
            && validStatusValue(request.resource.data.status_novo)
            && (
              request.resource.data.status_anterior == null
              || validStatusValue(request.resource.data.status_anterior)
            )
            && request.resource.data.keys().hasAny(['tipo_evento'])
            && validHistoricoTipoEvento(request.resource.data.tipo_evento)
          )
        || (
          verifiedCorporateUser()
          && request.resource.data.usuario_id == request.auth.uid
          && request.resource.data.usuario_email == request.auth.token.email
          && request.resource.data.tipo_evento == 'criacao'
          && request.resource.data.status_anterior == null
          && request.resource.data.status_novo == 'Nova'
          && request.resource.data.observacao == null
          && validProtocol()
          && getAfter(/databases/$(database)/documents/solicitacoes/$(request.resource.data.solicitacao_id)).data.created_by == request.auth.uid
        ));
      allow update, delete: if false;
    }
  }
}
