rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function verifiedCorporateUser() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('^[^@]+@protege\\.med\\.br$');
    }

    function isAdmin() {
      return verifiedCorporateUser()
        && request.auth.token.email in [
          'fabio@protege.med.br',
          'abner@protege.med.br',
          'esocial@protege.med.br'
        ];
    }

    function ownsSolicitacao(solicitacaoId) {
      return verifiedCorporateUser()
        && firestore.get(
          /databases/(default)/documents/solicitacoes/$(solicitacaoId)
        ).data.created_by == request.auth.uid;
    }

    match /solicitacoes/{solicitacaoId}/{fileName} {
      allow read: if isAdmin() || ownsSolicitacao(solicitacaoId);
      allow create: if verifiedCorporateUser()
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.metadata.solicitacao_id == solicitacaoId;
      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
